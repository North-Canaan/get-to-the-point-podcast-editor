# Required for highlight detection
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
ASSEMBLYAI_API_KEY=

# Required for WhisperX diarization in the worker environment
HF_TOKEN=
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
REASON_LANGUAGE=he

# Local development defaults
APP_BASE_URL=http://localhost:8000
DATA_DIR=data
STATE_BACKEND=filesystem
# Leave unset for default behavior: true locally, false on Vercel.
# RUN_INLINE_PIPELINE=true
WORKER_POLL_SECONDS=10

# Supabase production metadata/storage
# Recommended free-tier product: Supabase Postgres + Storage.
# Set STATE_BACKEND=supabase when these are configured.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=podcast-artifacts

# Better Auth (email/password; Supabase Auth is not used)
DATABASE_URL=
BETTER_AUTH_URL=http://localhost:8000
BETTER_AUTH_SECRET=
BETTER_AUTH_TRUSTED_ORIGINS=https://get-to-the-point-podcast-editor.vercel.app
TRUSTED_ORIGINS=http://localhost:8000,https://get-to-the-point-podcast-editor.vercel.app
RATE_LIMIT_SALT=

# Optional: send signed-in users their private podcast feed by email.
RESEND_API_KEY=
FEED_EMAIL_FROM=Get To The Point <feeds@your-domain.example>
